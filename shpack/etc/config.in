# SPDX-License-Identifier: MIT
#
# shpack configuration. @TOKEN@ placeholders are substituted by the launchers
# (stage.sh) on the host when staging (this replaces live-bootstrap's in-chroot
# configurator). Plain POSIX-shell assignments; sourced by bin/shpack.

ARCH=@ARCH@
JOBS=@JOBS@

# Store: one prefix per package, /opt/<name>-<version>-<hash7>. The kaem
# phase installs its packages as unhashed /opt/<name>-<version> prefixes,
# registered in etc/externals.
STORE=@STORE@

DISTFILES=@DISTFILES@

# The PATH floor under every composed build PATH: the kaem-phase prefixes
# (newest first) and the stage0 seed dirs.
BASEPATH=@BASEPATH@

# The tcc/musl bootstrap dash, used ONLY as the dag.mk driver-make shell (the
# top make that runs `shpack build-one` per node). It exists from the first kaem
# package on. Per-build shells are not taken from here: every built recipe
# declares its own dash dep and the builder's $sh follows it -- `depends_on dash`
# for the clean glibc dash, `depends_on dash@0.5.12` for this bootstrap one (the
# external below). On the host there is no writable /bin/sh, so this absolute
# store path is what drives builds unsandboxed; under chroot it == /bin/sh.
CONFIG_SHELL=@STORE@/dash-0.5.12/bin/sh

# When this spec occurs in a DAG, shpack builds it first, serially, under the
# bootstrap-era make (3.82, whose -j has races), then schedules the rest -jN
# under it.
SHPACK_BOOTSTRAP_MAKE=gmake@4.4.1

# The Landlock launcher each build step is wrapped in (kaem phase, built right
# after tcc+musl). Confines a build to the store (read+exec), the recipe tree
# and distfiles (read), and its own prefix plus scratch (write), so the host
# /usr is invisible and stray writes are denied. Leave empty to build
# unsandboxed (the test fixture does not set it).
SANDBOX=@STORE@/sandbox-1.0/bin/sandbox

# Rewrites `#!/bin/sh` shebangs in each unpacked source to the recipe's build
# shell ($sh, its declared dash) before building, since the sandbox has no host
# /bin/sh for install-sh/config.guess and friends. Leave empty to skip (the test
# fixture does not set it).
PATCH_SHEBANGS=@STORE@/patch-shebangs-1.0/bin/patch-shebangs
