	LOAD_W1_AHEAD
	SKIP_32_DATA
	%8
	ADD_X0_X17_X1
	POP_X1                # =:
	STR_X1_X0
	POP_X0
	PUSH_X0               # src (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%16
	ADD_X0_X17_X1
	POP_X1                # =:
	STR_X1_X0
	POP_X0
	PUSH_X0               # dest (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%24
	ADD_X0_X17_X1
	POP_X1                # =:
	STR_X1_X0
	POP_X0
	PUSH_X0               # d (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%32
	ADD_X0_X17_X1
	PUSH_X0               # dest (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%24
	ADD_X0_X17_X1
	LDR_X0_X0             # ?
	POP_X1                # =
	STR_X0_X1
	POP_X0                # ;
	PUSH_X0               # s (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%40
	ADD_X0_X17_X1
	PUSH_X0               # src (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%16
	ADD_X0_X17_X1
	LDR_X0_X0             # ?
	POP_X1                # =
	STR_X0_X1
	POP_X0                # ;
# stdlib.c 33
	PUSH_X0               # i (local)
	LOAD_W1_AHEAD
	SKIP_32_DATA
	%48
	ADD_X0_X17_X1
	PUSH_X0               # 0
	LOAD_W0_AHEAD
	SKIP_32_DATA
	%0
	POP_X1                # =
	STR_X0_X1
	POP_X0                # ;
