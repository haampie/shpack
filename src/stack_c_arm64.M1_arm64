	CMP_X1_X0
	CSET_X0_CC
	CMP_X0_0              # !
	CSET_X0_EQ
	CMP_X0_0              # if
	POP_X0
	SKIP_INST_NE
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&_memcpy_else2
