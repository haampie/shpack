	PUSH_X0               # 1
	LOAD_W0_AHEAD
	SKIP_32_DATA
	%1
	POP_X1                # -
	SUB_X0_X1_X0
	POP_X0                # ;
	LOAD_W16_AHEAD
	SKIP_32_DATA
	&_memcpy_loop1
