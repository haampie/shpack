# chroot build tree produced by build.sh
/rootfs/

# relocatable store produced by build-host.sh (chroot-free bootstrap)
/store/

# source tarballs: not committed (too large); fetched + verified by
# fetch-distfiles.sh, which carries the sha256/url manifest.
/distfiles/

# local reference checkouts (clean clones; not used by the build --
# build.sh uses vendor/stage0-posix/M2libc, and GNU Mes is replaced by
# vendor/mes-replacement/tcc_cc.c)
/M2libc/
/mes/
/live-bootstrap/
