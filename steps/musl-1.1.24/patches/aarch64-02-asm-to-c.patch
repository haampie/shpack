musl 1.1.24, AArch64: replace inline asm and .s sources with C raw-word emitters.

tcc 0.9.26 has no AArch64 instruction assembler and no inline-asm operand
constraints, so every hand-written .s file and asm() block is rewritten as C
that emits the same instruction words via ``__asm__(".int ...")``-free raw
.int/.word data (encodings verified with llvm-mc), or as plain C where the asm
only existed for register pinning:
  - arch/aarch64/crt_arch.h     _start as a C function
  - arch/aarch64/syscall_arch.h + src/internal/aarch64/syscall_raw.c
                                out-of-line syscall wrappers (raw ``svc``)
  - arch/aarch64/atomic_arch.h  LL/SC replaced with non-atomic C (single
                                threaded only -- revisit before pthread use)
  - arch/aarch64/pthread_arch.h __pthread_self out-of-line (mrs tpidr_el0)
  - crt/, src/fenv/, src/ldso/, src/setjmp/, src/signal/, src/thread/ under
    aarch64/: every .s replaced by an equivalent raw-word .c

Squashed from MES-replacement/steps/musl-1.1.24/patches 0005,0007,0008,0009,0021.
diff --git a/arch/aarch64/atomic_arch.h b/arch/aarch64/atomic_arch.h
index 40fefc2..3d05c27 100644
--- a/arch/aarch64/atomic_arch.h
+++ b/arch/aarch64/atomic_arch.h
@@ -1,82 +1,73 @@
+/* tcc 0.9.26 has no AArch64 assembler.  Real musl uses ldaxr/stlxr LL/SC
+ * pairs here; moving them out-of-line would break the monitor reservation,
+ * so we drop atomicity entirely and rely on the build being single-threaded.
+ *
+ * TODO(revisit): not safe once we link pthread paths or anything that uses
+ * a_cas under real concurrency.  When tcc gains aarch64 inline-asm support
+ * (or we patch one in), restore the upstream LL/SC implementations.
+ */
+
 #define a_ll a_ll
 static inline int a_ll(volatile int *p)
 {
-	int v;
-	__asm__ __volatile__ ("ldaxr %w0,%1" : "=r"(v) : "Q"(*p));
-	return v;
+	return *p;
 }
 
 #define a_sc a_sc
 static inline int a_sc(volatile int *p, int v)
 {
-	int r;
-	__asm__ __volatile__ ("stlxr %w0,%w2,%1" : "=&r"(r), "=Q"(*p) : "r"(v) : "memory");
-	return !r;
+	*p = v;
+	return 1;
 }
 
 #define a_barrier a_barrier
 static inline void a_barrier()
 {
-	__asm__ __volatile__ ("dmb ish" : : : "memory");
 }
 
 #define a_cas a_cas
 static inline int a_cas(volatile int *p, int t, int s)
 {
-	int old;
-	do {
-		old = a_ll(p);
-		if (old != t) {
-			a_barrier();
-			break;
-		}
-	} while (!a_sc(p, s));
+	int old = *p;
+	if (old == t) *p = s;
 	return old;
 }
 
 #define a_ll_p a_ll_p
 static inline void *a_ll_p(volatile void *p)
 {
-	void *v;
-	__asm__ __volatile__ ("ldaxr %0, %1" : "=r"(v) : "Q"(*(void *volatile *)p));
-	return v;
+	return *(void *volatile *)p;
 }
 
 #define a_sc_p a_sc_p
 static inline int a_sc_p(volatile int *p, void *v)
 {
-	int r;
-	__asm__ __volatile__ ("stlxr %w0,%2,%1" : "=&r"(r), "=Q"(*(void *volatile *)p) : "r"(v) : "memory");
-	return !r;
+	*(void *volatile *)p = v;
+	return 1;
 }
 
 #define a_cas_p a_cas_p
 static inline void *a_cas_p(volatile void *p, void *t, void *s)
 {
-	void *old;
-	do {
-		old = a_ll_p(p);
-		if (old != t) {
-			a_barrier();
-			break;
-		}
-	} while (!a_sc_p(p, s));
+	void *old = *(void *volatile *)p;
+	if (old == t) *(void *volatile *)p = s;
 	return old;
 }
 
 #define a_ctz_64 a_ctz_64
 static inline int a_ctz_64(uint64_t x)
 {
-	__asm__(
-		"	rbit %0, %1\n"
-		"	clz %0, %0\n"
-		: "=r"(x) : "r"(x));
-	return x;
+	int n = 0;
+	if (!x) return 64;
+	while (!(x & 1)) { x >>= 1; n++; }
+	return n;
 }
 
 #define a_clz_64 a_clz_64
 static inline int a_clz_64(uint64_t x)
 {
-	__asm__("clz %0, %1" : "=r"(x) : "r"(x));
-	return x;
+	int n = 0;
+	if (!x) return 64;
+	while (!(x & ((uint64_t)1 << 63))) { x <<= 1; n++; }
+	return n;
 }
diff --git a/arch/aarch64/crt_arch.h b/arch/aarch64/crt_arch.h
index b64fb3d..79074bf 100644
--- a/arch/aarch64/crt_arch.h
+++ b/arch/aarch64/crt_arch.h
@@ -1,15 +1,24 @@
-__asm__(
-".text \n"
-".global " START "\n"
-".type " START ",%function\n"
-START ":\n"
-"	mov x29, #0\n"
-"	mov x30, #0\n"
-"	mov x0, sp\n"
-".weak _DYNAMIC\n"
-".hidden _DYNAMIC\n"
-"	adrp x1, _DYNAMIC\n"
-"	add x1, x1, #:lo12:_DYNAMIC\n"
-"	and sp, x0, #-16\n"
-"	b " START "_c\n"
-);
+/* tcc 0.9.26 has no AArch64 assembler, so the _start glue is written in C
+ * and emitted as raw instruction words via __asm__(".int 0x..").
+ *
+ * tcc's aarch64 function prologue is "stp x29,x30,[sp,#-224]!; mov x29,sp",
+ * so on entry to _start the kernel-provided stack image (argc, argv[], NULL,
+ * envp[], NULL, auxv...) starts at x29+224.  We pass that pointer to
+ * _start_c as its sole argument.  _DYNAMIC is omitted because this build is
+ * --disable-shared and _start_c never reads its second argument in that mode.
+ *
+ * Encodings (verified with llvm-mc --triple=aarch64):
+ *   add x0, x29, #224  = 0x910383a0
+ */
+
+void _start_c();    /* K&R unspecified-args decl matches the mes-aarch64
+                       crt1.c trick: with no prototype, tcc does not
+                       shuffle argument registers around the call, so x0
+                       set immediately above survives into _start_c. */
+
+void _start(void)
+{
+	__asm__(".int 0x910383a0"); /* add x0, x29, #224  ; x0 = sp at entry */
+	_start_c();
+	/* _start_c -> __libc_start_main -> exit(); never returns. */
+}
diff --git a/arch/aarch64/pthread_arch.h b/arch/aarch64/pthread_arch.h
index e64b126..1adca0d 100644
--- a/arch/aarch64/pthread_arch.h
+++ b/arch/aarch64/pthread_arch.h
@@ -1,8 +1,15 @@
+/* tcc 0.9.26 has no AArch64 assembler.  The thread-pointer read
+ *   __asm__("mrs %0,tpidr_el0" : "=r"(self))
+ * cannot be expressed (no inline-asm operands), so the raw mrs lives in
+ * src/internal/aarch64/syscall_raw.c::__aarch64_read_tp() and we call it
+ * here.  Single-threaded use means tpidr_el0 is only set once by
+ * __init_tp(), so the indirection cost is irrelevant.
+ */
+void *__aarch64_read_tp(void);
+
 static inline struct pthread *__pthread_self()
 {
-	char *self;
-	__asm__ ("mrs %0,tpidr_el0" : "=r"(self));
-	return (void*)(self - sizeof(struct pthread));
+	return (struct pthread *)((char *)__aarch64_read_tp() - sizeof(struct pthread));
 }
 
 #define TLS_ABOVE_TP
