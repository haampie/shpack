+__asm__(
+    ".text\n"
+    ".balign 4\n"
+    ".global __restore\n"
+    ".hidden __restore\n"
+    ".type __restore,@function\n"
+    "__restore:\n"
+    ".global __restore_rt\n"
+    ".hidden __restore_rt\n"
+    ".type __restore_rt,@function\n"
+    "__restore_rt:\n"
+    ".int 0xd2801168\n"   /* mov x8, #139  (SYS_rt_sigreturn) */
+    ".int 0xd4000001\n"   /* svc #0                            */
+);
