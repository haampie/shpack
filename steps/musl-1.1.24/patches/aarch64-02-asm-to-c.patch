+    "fegetenv:\n"
+    ".int 0xd53b4401\n"   /* mrs x1, fpcr        */
+    ".int 0xd53b4422\n"   /* mrs x2, fpsr        */
+    ".int 0x29000801\n"   /* stp w1, w2, [x0]    */
+    ".int 0x52800000\n"   /* mov w0, #0          */
