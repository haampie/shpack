From 6dce21fca8aaa1806b2d10dbbb62dbfd318e5d34 Mon Sep 17 00:00:00 2001
From: Harmen Stoppels <me@harmenstoppels.nl>
Date: Tue, 2 Jun 2026 20:45:38 +0200
Subject: [PATCH 2/2] sigsetjmp-x86_64-plt

Signed-off-by: Harmen Stoppels <me@harmenstoppels.nl>
---
 src/signal/x86_64/sigsetjmp.s | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/signal/x86_64/sigsetjmp.s b/src/signal/x86_64/sigsetjmp.s
index 9a7695f..d354d68 100644
--- a/src/signal/x86_64/sigsetjmp.s
+++ b/src/signal/x86_64/sigsetjmp.s
@@ -11,7 +11,7 @@ __sigsetjmp:
 	mov %rbx,72+8(%rdi)
 	mov %rdi,%rbx
 
-	call setjmp@PLT
+	call setjmp
 
 	pushq 64(%rbx)
 	mov %rbx,%rdi
@@ -21,4 +21,4 @@ __sigsetjmp:
 .hidden __sigsetjmp_tail
 	jmp __sigsetjmp_tail
 
-1:	jmp setjmp@PLT
+1:	jmp setjmp
-- 
2.43.0

