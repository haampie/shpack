
static void parse_builtin_params(int nc, const char *args)
{
    char c;
    char sep = '(';
    CType t;
    int i;
    if (nc)
        nocode_wanted++;
    next();
    for (i = 0; args[i] != 0; i = i + 1) {
	c = args[i];
	skip(sep);
	sep = ',';
	if (c == 'e')
	    expr_eq();
	else if (c == 't')
	    {
		parse_type(&t);
		vpush(&t);
	    }
	else
	    tcc_error("internal error");
    }
    skip(')');
    if (nc)
