DISTFILES=/external/distfiles
PREFIX=/usr
BINDIR=${PREFIX}/bin
# The libc (musl) lives in its own store prefix, just like every other package.
# INCDIR/LIBDIR are the libc's header/lib dirs; they are expanded once here (not
# tied to PREFIX), so the kaem phase can override PREFIX/BINDIR per package while
# every step still finds musl under LIBC_PREFIX. tcc bakes these in as its
# sysinclude / crt-prefix, and gcc-linaro/binutils point their sysroot here.
LIBC_PREFIX=/opt/musl-1.1.24
LIBDIR=${LIBC_PREFIX}/lib
INCDIR=${LIBC_PREFIX}/include
SRCDIR=/steps
TMPDIR=/tmp
# Shell-phase store root + inner-make parallelism. Plain assignments (no
# `export`) so this file stays kaem-parseable for the kaem phase, which embeds
# it verbatim; build-one.sh re-sources env and exports what subprocesses need.
# The old improve/update_env.sh PATH glob is gone: PATH is composed per package
# by the dag.mk recipes (closure + BASEPATH) the script-generator emits.
PKGDIR=/opt
MAKEJOBS=-j${JOBS}
