# This file follows a very simple, human readable and machine parseable syntax.
# Each line is in the format:
# <directive>: <arguments> <predicate>
#
# The supported directives and arguments are:
# - build; simply builds a particular package.
#   eg, build: make-3.82
# - improve; runs a script that makes a distinct and logical improvement to the system.
#   eg, improve: use_fhs
# - define: define a variable based upon other variables
#   eg, define: BUILD_FIWIX = KERNEL_BOOTSTRAP == True || BUILD_KERNELS == True
# - jump: jump (usually) to a new kernel, executes a script with that name
#   eg, jump: fiwix
# - uninstall; removes a package or filenames
#   eg, uninstall: perl-5.6.2
#   eg, uninstall: /usr/bin/lex /usr/bin/flex
#
# The following directives have special significance:
# - build directives beginning with "dash" (the first shell; as well as jumps)
#   trigger the generation of a new script
# - the first improve directive containing "network" is used by generator.py to deduce
#   what source files need to be downloaded in advance (files referenced after that will
#   be downloaded during bootstrap, unless --external-sources is given)
#
# Other features:
# - predicate; based on variables set in bootstrap.cfg, require for something to execute
#   must be enclosed in brackets with spaces padded
#   eg, build: fiwix-1.5.0-lb1 ( BUILD_FIWIX == True )

build: checksum-transcriber-1.0
build: simple-patch-1.0
build: tcc-0.9.26
# Grow the bring-up subset libc into FULL musl 1.1.24 (amd64 + aarch64), built by
# the seed-grown tcc 0.9.26, for the downstream binutils/gcc bootstrap.
#
# This MUST run before tcc-0.9.27: tcc parses decimal float literals via the
# strtod() that is statically linked into the tcc binary. The bring-up SUBSET
# musl's strtod mis-parses any mantissa with >=20 significant digits (e.g. gcc
# real.c's M_LOG10_2 = 0.30102999566398119521), so a tcc linked against it
# miscompiles gcc/real.c (cc1 ICEs at real.c:1724). Building full musl first means
# the next tcc links the CORRECT full-musl strtod. (This is also the real reason
# 0.9.26 "ICEs gcc's real.c" -- same strtod bug, not a tccgen/codegen difference.)
build: musl-1.1.24
# Upgrade the seed-grown 0.9.26 to the 0.9.27 release, now built by 0.9.26 against
# the FULL musl (float-correct strtod). Production compiler from here on (amd64 +
# aarch64); 0.9.27 also carries post-snapshot tccgen.c fixes for cleaner codegen.
build: tcc-0.9.27

# Core userland, built by the production tcc against full musl (live-bootstrap's
# post-tcc kaem phase). make first (needs only tcc + mescc-tools), then patch
# (every later package applies real unified diffs), up to a working /bin/sh.
# dash is the LAST kaem-phase package and becomes /bin/sh; the script-generator
# splits a new (shell) script at the "dash-" prefix, so everything after dash
# runs under dash instead of kaem.
build: make-3.82
build: patch-2.5.9
build: gzip-1.2.4
build: tar-1.12
build: sed-4.0.9
build: bzip2-1.0.8
build: coreutils-5.0
build: oyacc-6.6
build: dash-0.5.12

# From here on (the shell phase) every package installs into its own prefix
# /opt/<name-version> (a Spack-style store). Build order and per-package PATH are
# no longer linear: the script-generator emits /steps/dag.mk from each package's
# steps/<name-version>/deps file and GNU make schedules the DAG (see DAG.md). The
# store-env setup that the old `improve: update_env` did is now static (steps/env
# + build-one.sh); the runtime /opt/*/bin PATH glob is gone. Installed trees are
# not checksummed during the build; verification is post-hoc (see IDEAS.md).

# Basic Unix utilities, all compiled by TCC 0.9.26 against musl 1.1.24.
# Skips the live-bootstrap perl+autoconf+automake chain entirely — we use
# tarballs with pre-generated configure scripts so none of that is needed.
# These build under the bootstrap make-3.82 and provide grep/sed/gawk that
# make-4.4.1's configure (next) needs.
build: grep-2.4
build: m4-1.4.7
build: diffutils-2.7
build: gawk-3.0.4

# Replace bootstrap make-3.82 with make-4.4.1: fixes 3.82's parallel-build
# races and adds the robust fifo jobserver, so the heavy steps below
# (binutils/gmp/mpfr/mpc/gcc) build correctly in parallel. Built under dash with
# its bundled ./build.sh (shell + tcc only, no make-to-build-make).
build: make-4.4.1

# Toolchain for GCC: assembler/linker first, then GCC's arithmetic prerequisites.
# All compiled by TCC 0.9.26 against musl. No autoconf/automake chain needed —
# these tarballs ship pre-generated configure scripts.
build: binutils-2.30
build: gmp-4.3.2
build: mpfr-2.4.2
build: mpc-1.0.3

# First real C compiler: GCC 4.7 Linaro (native aarch64/amd64, C only).
# Linaro 4.7-2013.11 is used because FSF GCC 4.7 lacks native aarch64 support.
build: gcc-linaro-4.7-2013.11

