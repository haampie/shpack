            else if (!PATHCMP(ext, "c") || !PATHCMP(ext, "i"))
                filetype = AFF_TYPE_C;
            else if (s->output_type == TCC_OUTPUT_PREPROCESS)
                /* Bootstrap/0.9.26 behavior: under -E, preprocess any file
